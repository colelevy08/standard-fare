# ─────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your Supabase values
# ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API

REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Preview password gate (remove this line to disable the gate after owner approval)
REACT_APP_PREVIEW_PASSWORD=yourpreviewpassword
