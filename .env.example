# ─────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────
# See docs/CREDENTIALS-CHECKLIST.md for where to find each value.

# ── Supabase (required) ──────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Preview password gate (optional) ────────────────────────────
# Remove this line entirely to disable the gate after owner approval
REACT_APP_PREVIEW_PASSWORD=yourpreviewpassword

# ── Toast POS (required for online checkout) ────────────────────
# Get from: Toast Developer Portal → API Keys
# Set these in Vercel Environment Variables for production
TOAST_API_KEY=your-toast-api-key
TOAST_RESTAURANT_ID=your-restaurant-guid
TOAST_API_URL=https://ws-api.toasttab.com
